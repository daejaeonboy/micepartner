rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentAdminDocPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function currentAdminProfileExists() {
      return isSignedIn() && exists(currentAdminDocPath());
    }

    function currentAdminApproved() {
      return currentAdminProfileExists() &&
        (
          !('approved' in get(currentAdminDocPath()).data) ||
          get(currentAdminDocPath()).data.approved == true
        );
    }

    function isOwnAdminDoc(adminUid) {
      return isSignedIn() && request.auth.uid == adminUid;
    }

    function ownAdminProfileCreateAllowed(adminUid) {
      return isOwnAdminDoc(adminUid) &&
        !exists(/databases/$(database)/documents/admins/$(adminUid)) &&
        (
          !('approved' in request.resource.data) ||
          request.resource.data.approved == false
        );
    }

    function ownAdminProfileUpdateAllowed(adminUid) {
      return isOwnAdminDoc(adminUid) &&
        (
          (
            !('approved' in resource.data) &&
            !('approved' in request.resource.data)
          ) ||
          (
            ('approved' in resource.data ? resource.data.approved : false) ==
            ('approved' in request.resource.data ? request.resource.data.approved : false)
          )
        );
    }

    match /siteData/{docId} {
      allow read: if true;
      allow write: if currentAdminApproved();
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if currentAdminApproved();
    }

    match /admins/{adminUid} {
      allow read: if isOwnAdminDoc(adminUid) || currentAdminApproved();
      allow create: if ownAdminProfileCreateAllowed(adminUid) || currentAdminApproved();
      allow update: if ownAdminProfileUpdateAllowed(adminUid) || currentAdminApproved();
      allow delete: if currentAdminApproved();
    }
  }
}
