# Legacy Express API envs (optional when Firebase-only)
API_PORT=8787
DB_PATH=data/micepartner.sqlite
VITE_API_ORIGIN=
ALLOWED_ORIGINS=https://your-custom-domain.com,https://www.your-custom-domain.com,https://your-project-id.web.app,https://your-project-id.firebaseapp.com
GOOGLE_CLIENT_ID=

# Firebase Web App envs (required)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
